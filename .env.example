# ─────────────────────────────────────────────────────────────
# PaperChai — Required Environment Variables
# Copy this file to .env.local and fill in your values.
# ─────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/paperchai"
# Optional: direct connection (e.g. Supabase) for migrations when DATABASE_URL uses the pooler
# DIRECT_URL="postgresql://user:password@host:5432/postgres"

# Production DB (for migrations only). Used by: npm run db:migrate:prod
# Do not commit real values; set in .env.local or a secrets manager.
# DATABASE_URL_PROD="postgresql://..."
# DIRECT_URL_PROD="postgresql://..."

# ── NextAuth ──────────────────────────────────────────────────
NEXTAUTH_URL="https://your-domain.com"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# ── Google OAuth (for Sign in with Google) ───────────────────
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ── Google Gemini AI ──────────────────────────────────────────
GOOGLE_API_KEY="your-gemini-api-key"

# ── Email / SMTP (for sending invoices and reminders) ─────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-email@example.com"
SMTP_PASS="your-app-password"
SMTP_FROM="PaperChai <noreply@your-domain.com>"

# ── Encryption (for OAuth token storage) ─────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="your-64-character-hex-key"

# ── Cron job authentication ───────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET="your-random-cron-secret"

# ── Owner access (comma-separated emails for admin/OWNER tier) ─
OWNER_EMAILS="you@example.com"

# ── App URL (used in emails and OAuth callbacks) ──────────────
NEXT_PUBLIC_APP_URL="https://your-domain.com"

# ── Razorpay (server: payment links, webhooks, refunds; optional client hint for invoice UI) ──
# Use either pair — same values Razorpay shows as Key ID + Key Secret:
# RAZORPAY_KEY_ID=rzp_...
# RAZORPAY_KEY_SECRET=...
# Or common aliases:
# RAZORPAY_API_KEY=rzp_...
# RAZORPAY_SECRET=...
# Webhook HMAC verification:
# RAZORPAY_WEBHOOK_SECRET=...
# Optional: show “Razorpay available” in invoice editor without exposing the secret (Key ID only):
# NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_...
# NEXT_PUBLIC_RAZORPAY_API_KEY=rzp_...

# ── Optional: Integrations (see .env.integrations.example) ───
# SLACK_CLIENT_ID=
# SLACK_CLIENT_SECRET=
# SLACK_SIGNING_SECRET=
# NOTION_CLIENT_ID=
# NOTION_CLIENT_SECRET=
# NOTION_API_VERSION=2022-06-28
