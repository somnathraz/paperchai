# ─────────────────────────────────────────────────────────────
# PaperChai — Required Environment Variables
# Copy this file to .env.local and fill in your values.
# ─────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/paperchai"

# ── NextAuth ──────────────────────────────────────────────────
NEXTAUTH_URL="https://your-domain.com"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# ── Google OAuth (for Sign in with Google) ───────────────────
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ── Google Gemini AI ──────────────────────────────────────────
GOOGLE_API_KEY="your-gemini-api-key"

# ── Email / SMTP (for sending invoices and reminders) ─────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-email@example.com"
SMTP_PASS="your-app-password"
SMTP_FROM="PaperChai <noreply@your-domain.com>"

# ── Encryption (for OAuth token storage) ─────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="your-64-character-hex-key"

# ── Cron job authentication ───────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET="your-random-cron-secret"

# ── Owner access (comma-separated emails for admin/OWNER tier) ─
OWNER_EMAILS="you@example.com"

# ── App URL (used in emails and OAuth callbacks) ──────────────
NEXT_PUBLIC_APP_URL="https://your-domain.com"

# ── Optional: Integrations (see .env.integrations.example) ───
# SLACK_CLIENT_ID=
# SLACK_CLIENT_SECRET=
# SLACK_SIGNING_SECRET=
# NOTION_CLIENT_ID=
# NOTION_CLIENT_SECRET=
# NOTION_API_VERSION=2022-06-28
