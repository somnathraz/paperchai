    },
    "app/api/internal/reminders/run/route.ts": {
      "maxDuration": 60
    },
    "app/api/internal/scheduled-invoices/run/route.ts": {
      "maxDuration": 60
    },
    "app/api/internal/automation/run/route.ts": {
      "maxDuration": 60
    },
    "app/api/internal/approvals/escalate/route.ts": {
      "maxDuration": 60
    },
    "app/api/internal/recurring-invoices/run/route.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    { "path": "/api/internal/cron/daily", "schedule": "0 2 * * *" },
    { "path": "/api/internal/approvals/escalate", "schedule": "0 3 * * *" }
  ]
}
